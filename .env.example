# Copy this file to .env and adjust values for your machine.

HERMES_IMAGE=nousresearch/hermes-agent:v2026.6.5
HERMES_DATA_DIR=./data
HERMES_UID=1000
HERMES_GID=1000
HERMES_DASHBOARD_PORT=9119
FIRECRAWL_API_KEY=
FIRECRAWL_API_URL=https://api.firecrawl.dev
FIRECRAWL_BROWSER_TTL=300
OPENAI_API_KEY=
OPENAI_BASE_URL=
APPLE_CALDAV_URL=https://caldav.icloud.com
APPLE_CALDAV_USERNAME=
APPLE_CALDAV_APP_PASSWORD=
CALDAV_MCP_BEARER_TOKEN=
HERMES_API_SERVER_KEY=change-me
MESSAGING_API_PORT=3000
MESSAGING_API_JWT_SECRET=change-me
MESSAGING_API_HOST=100.x.x.x:3000
INVITE_EXPIRY_HOURS=48
MIN_PASSWORD_LENGTH=12
COMPANION_MCP_BEARER_TOKEN=replace-with-long-random-token
CRON_WEBHOOK_BEARER=replace-with-long-random-token
CRON_OUTPUT_DIR=/opt/data/cron/output
CRON_OUTPUT_POLL_MS=5
ADDRESS_ENRICHMENT_SESSION_ID=companion-address-enrichment
APNS_ENABLED=false
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=
APNS_KEY_PATH=/opt/data/apns/AuthKey_XXXXXX.p8
APNS_ENVIRONMENT=development
PUSH_PREVIEW_MAX_CHARS=120
# SYNC_INBOX_MAX_GAP=500
