# Host port for the daemon API and CDP gateway (Hermes uses this from Docker).
PORT=9221

# Local Brave DevTools port (not published; proxied by the daemon).
BRAVE_CDP_PORT=9222

# Persistent Brave profile name and directory under HERMES_DATA_DIR.
BRAVE_PROFILE_NAME=hermes
HERMES_DATA_DIR=../data

# Hostname/port Docker clients use in rewritten CDP websocket URLs.
CDP_PUBLIC_HOST=host.docker.internal
CDP_PUBLIC_PORT=9221

# macOS Brave binary (override on other platforms if needed).
BRAVE_APP=/Applications/Brave Browser.app/Contents/MacOS/Brave Browser